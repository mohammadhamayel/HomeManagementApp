{
  "name": "beiti",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "start:lan": "expo start --lan",
    "android": "expo start --android --lan",
    "ios": "expo start --ios --lan",
    "ios:device": "expo run:ios --device \"iPhone\"",
    "ios:device:release": "expo run:ios --device \"iPhone\" --configuration Release --no-bundler",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "expo:login": "expo login"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
